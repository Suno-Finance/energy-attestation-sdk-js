{
  "name": "energy-attestation-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Energy Attestation Service — on-chain energy reporting via EAS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "ethereum",
    "eas",
    "attestation",
    "energy",
    "web3",
    "sdk",
    "EVM"
  ],
  "author": "Suno",
  "license": "MIT",
  "homepage": "https://attest.energy",
  "repository": {
    "type": "git",
    "url": "https://github.com/Suno-Finance/energy-attestation-sdk-js"
  },
  "bugs": {
    "url": "https://github.com/Suno-Finance/energy-attestation-sdk-js/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "ethers": "^6.16.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
